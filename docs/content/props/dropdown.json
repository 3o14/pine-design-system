[
  {
    "name": "options",
    "type": "DropdownOption[]",
    "description": "List of options available for selection.",
    "required": true
  },
  {
    "name": "value",
    "type": "string",
    "description": "Currently selected value (controlled).",
    "required": false
  },
  {
    "name": "defaultValue",
    "type": "string",
    "description": "Initial selected value (uncontrolled).",
    "required": false
  },
  {
    "name": "onValueChange",
    "type": "(value: string | null) => void",
    "description": "Callback invoked when the selected value changes.",
    "required": false
  },
  {
    "name": "placeholder",
    "type": "string",
    "description": "Placeholder text when no option is selected.",
    "default": "\"Select an option\"",
    "required": false
  },
  {
    "name": "size",
    "type": "\"small\" | \"medium\" | \"large\"",
    "description": "Controls the dropdown size.",
    "default": "\"medium\"",
    "required": false
  },
  {
    "name": "rounded",
    "type": "\"small\" | \"medium\" | \"large\"",
    "description": "Controls the corner radius of the dropdown.",
    "default": "\"medium\"",
    "required": false
  },
  {
    "name": "intent",
    "type": "\"primary\" | \"secondary\" | \"success\" | \"warning\" | \"danger\" | \"neutral\"",
    "description": "Controls the color intent of the dropdown.",
    "default": "\"primary\"",
    "required": false
  },
  {
    "name": "fullWidth",
    "type": "boolean",
    "description": "When true, the dropdown fills the full width of its parent container.",
    "default": "false",
    "required": false
  },
  {
    "name": "disabled",
    "type": "boolean",
    "description": "Disables the dropdown.",
    "default": "false",
    "required": false
  }
]
